# Canonical public URL.
SITE_URL=https://example.com

# Use "/" for custom domain deployments.
# Use "/<repository-name>/" for GitHub Pages project-site deployments.
BASE_PATH=/

# Main Augur site URL used by the header link.
PUBLIC_MAIN_SITE_URL=https://augur.net

# Optional private RPC URL used only by GitHub Actions.
# Never expose this as PUBLIC_*.
ETH_RPC_URL=

# Optional public-safe label for ETH_RPC_URL in generated provenance.
# Example: Alchemy Mainnet, Infura Mainnet, Internal Mainnet RPC.
ETH_RPC_LABEL=

# Optional debug/performance logging.
PERF_LOGS=false
