{
  "name": "augur-forkwatch-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && astro preview",
    "generate:migration-progress": "bun run scripts/generate-migration-progress.ts",
    "validate:data": "bun run scripts/validate-migration-progress.ts",
    "typecheck": "astro check",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "check": "bun run typecheck && bun run lint && bun run test && bun run validate:data"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "astro": "^6.4.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
